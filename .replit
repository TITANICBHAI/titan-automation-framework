modules = ["bash", "nix", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push to GitHub"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/setup.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Push to GitHub"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export GITHUB_TOKEN=\"$GITHUB_PERSONAL_ACCESS_TOKEN\"; bash scripts/github-push.sh \"fix: remove working-directory: titan-automation from CI workflow — project root IS Android root\""
