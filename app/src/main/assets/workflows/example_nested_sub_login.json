{
  "workflow_id": "example_nested_sub_login",
  "name": "Login Sub-Workflow",
  "description": "Reusable login automation invoked via INVOKE_WORKFLOW from any parent workflow. Fills username + password, taps Login, waits for main menu.",
  "version": "1.0",
  "initial_state": "tap_username_field",
  "global_timeout_ms": 45000,
  "states": {
    "tap_username_field": {
      "state_id": "tap_username_field",
      "description": "Tap the username input field to focus it",
      "timeout_ms": 6000,
      "max_retries": 2,
      "actions": [
        {
          "interaction_type": "TAP",
          "x": 0.5,
          "y": 0.38,
          "delay_after_ms": 400
        }
      ],
      "on_success": "type_username",
      "on_failure": "END"
    },

    "type_username": {
      "state_id": "type_username",
      "description": "Type username into the focused field",
      "timeout_ms": 5000,
      "max_retries": 1,
      "actions": [
        {
          "interaction_type": "TYPE_TEXT",
          "x": 0.5,
          "y": 0.38,
          "text_input": "player_username",
          "delay_after_ms": 300
        }
      ],
      "on_success": "tap_password_field",
      "on_failure": "END"
    },

    "tap_password_field": {
      "state_id": "tap_password_field",
      "description": "Tap the password field",
      "timeout_ms": 5000,
      "max_retries": 2,
      "actions": [
        {
          "interaction_type": "TAP",
          "x": 0.5,
          "y": 0.52,
          "delay_after_ms": 400
        }
      ],
      "on_success": "type_password",
      "on_failure": "END"
    },

    "type_password": {
      "state_id": "type_password",
      "description": "Type password into the focused field",
      "timeout_ms": 5000,
      "max_retries": 1,
      "actions": [
        {
          "interaction_type": "TYPE_TEXT",
          "x": 0.5,
          "y": 0.52,
          "text_input": "player_password",
          "delay_after_ms": 300
        }
      ],
      "on_success": "tap_login_button",
      "on_failure": "END"
    },

    "tap_login_button": {
      "state_id": "tap_login_button",
      "description": "Tap the Login button and wait for main menu to appear",
      "timeout_ms": 15000,
      "max_retries": 2,
      "vision_rule": {
        "template_name": "login_button.png",
        "threshold": 0.80,
        "match_mode": "TEMPLATE"
      },
      "ocr_scan_rule": {
        "regex_pattern": "play|main.menu|home",
        "min_confidence": 0.75,
        "fuzzy_match": false
      },
      "actions": [
        {
          "interaction_type": "TAP",
          "x": 0.5,
          "y": 0.68,
          "duration_ms": 80,
          "delay_after_ms": 2000
        }
      ],
      "on_success": "END",
      "on_failure": "END"
    }
  }
}
